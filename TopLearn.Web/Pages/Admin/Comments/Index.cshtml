@page
@using TopLearn.Core.DTOs
@model TopLearn.Web.Pages.Admin.Comments.IndexModel
@{
    ViewData["Title"] = "لیست کامنت ها";
}

<div class="row">
    <div class="col-lg-12">
        <h1 class="page-header">لیست کامنت ها</h1>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="panel panel-default">
            <div class="panel-heading">
                لیست نت ها
            </div>
            <div class="panel-body">
                <div class="table-responsive">
                    <div id="dataTables-example_wrapper" class="dataTables_wrapper form-inline" role="grid">
                        <table class="table table-striped table-bordered table-hover dataTable no-footer" id="dataTables-example" aria-describedby="dataTables-example_info">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>وضعیت</th>
                                    <th>نام</th>
                                    <th>متن کامنت</th>
                                    <th>متن جواب</th>
                                    <th>مرتبط یا</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Comments)
                                {
                                    <tr>
                                        <td>
                                            <form method="post">
                                                @if (item.IsShowOnSite)
                                                {
                                                    <button asp-page-handler="ShowInSite" asp-route-id="@item.CommentId" class="btn btn-warning btn-sm">
                                                        عدم نمایش در سایت
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button asp-page-handler="ShowInSite" asp-route-id="@item.CommentId" class="btn btn-info btn-sm">
                                                        نمایش در سایت
                                                    </button>
                                                }
                                               
                                            
                                            <a href="/Admin/Comments/AnswerComment/@item.CommentId" class="btn btn-success btn-sm">
                                                جواب دادن
                                            </a>
                                            </form>
                                        </td>
                                        <td>
                                            @if (item.IsShowOnSite)
                                            {
                                                <i class="fa fa-check-circle text-success fa-2x"></i>
                                            }
                                            else
                                            {
                                                <i class="fa fa-minus-circle text-warning fa-2x"></i>
                                            }

                                        </td>
                                        <td>@item.FullName</td>
                                        <td>@item.CommentText</td>
                                        <td>
                                            @if (@item.Comments.Any())
                                            {
                                                @item.Comments.FirstOrDefault().CommentText
                                            }
                                        </td>
                                        <td>
                                            @{
                                                switch (item.CommentType)
                                                {
                                                    case (int)ConstantValue.CommentType.StudentConcert:
                                                        @($"{item.StudentConcert.Title}")
                                                        break;
                                                    case (int)ConstantValue.CommentType.Instrument:
                                                        @($"{item.Instrument.InstrumentTitle}")
                                                        break;
                                                    case (int)ConstantValue.CommentType.Product:
                                                        @($"{item.Product.CourseTitle}")
                                                        break;
                                                    default:
                                                        @("")
                                                        break;
                                                }
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
