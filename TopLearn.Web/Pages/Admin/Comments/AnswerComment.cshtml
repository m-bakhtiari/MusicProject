@page "{id}"
@model TopLearn.Web.Pages.Admin.Comments.AnswerCommentModel
@{
    ViewData["Title"] = "جواب";
}
<div class="row">
    <div class="col-lg-12">
        <h1 class="page-header">پاسخ به کامنت</h1>
    </div>
    <!-- /.col-lg-12 -->
</div>

<div class="row">
    <form method="post">
        <input type="hidden" asp-for="Comment.ParentId" />
        <input type="hidden" asp-for="Comment.InstrumentId" />
        <input type="hidden" asp-for="Comment.StudentConcertId" />
        <input type="hidden" asp-for="Comment.ProductId" />
        <input type="hidden" asp-for="Comment.CommentType" />
        <input type="hidden" asp-for="Comment.FullName" />
        <input type="hidden" asp-for="Comment.Mobile" />
        <input type="hidden" asp-for="Comment.UserId" />

        <div class="col-md-8">
            <div class="form-group">
                <label>متن جواب شما</label>
                <input type="text" asp-for="Comment.CommentText" class="form-control" required>
            </div>

            <input type="submit" value="ذخیره اطلاعات" class="btn btn-success" />

        </div>
    </form>
</div>