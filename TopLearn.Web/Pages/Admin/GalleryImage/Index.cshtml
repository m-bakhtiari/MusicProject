@page
@using TopLearn.Core.DTOs
@model TopLearn.Web.Pages.Admin.GalleryImage.IndexModel
@{
    ViewData["Title"] = "لیست تصاویر";
}

<div class="row">
    <div class="col-lg-12">
        <h1 class="page-header">لیست تصاویر</h1>
    </div>
    <!-- /.col-lg-12 -->
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="panel panel-default">
            <div class="panel-heading">
                لیست تصاویر
            </div>
            <!-- /.panel-heading -->
            <div class="panel-body">
                <div class="table-responsive">
                    <div id="dataTables-example_wrapper" class="dataTables_wrapper form-inline" role="grid">
                        <div class="col-md-12" style="margin: 10px 0;">

                            <a asp-page="CreateGalleryImage" class="btn btn-outline btn-success">افزودن عکس جدید</a>

                        </div>
                        <table class="table table-striped table-bordered table-hover dataTable no-footer" id="dataTables-example" aria-describedby="dataTables-example_info">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>عکس</th>

                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.GalleryImages)
                                {
                                    <tr>
                                        <td>
                                            <a href="/Admin/GalleryImage/DeleteGalleryImage/@item.GalleryImageId" class="btn btn-info btn-sm mt-2">
                                                حذف
                                            </a>
                                        </td>
                                        <td><img src="../galleryImage/@item.ImageName" alt="image" class="thumbnail thumb img-thumbnail"/></td>

                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
            <!-- /.panel-body -->
        </div>
        <!-- /.panel -->
    </div>
    <!-- /.col-lg-12 -->
</div>
