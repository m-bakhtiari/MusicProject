@page

@model TopLearn.Web.Pages.Admin.MusicNote.CreateMusicNoteModel
@{
    ViewData["Title"] = "افزودن نت جدید";
}


<div class="row">
    <div class="col-lg-12">
        <h1 class="page-header">افزودن نت جدید</h1>
    </div>
    <!-- /.col-lg-12 -->
</div>

<div class="row">
    <form method="post" enctype="multipart/form-data">
        <div class="col-md-8">
            <div class="form-group">
                <label>نام ساز</label>
                <select class="form-control" asp-for="MusicNote.InstrumentId" asp-items="@(ViewData["Instruments"] as SelectList)"></select>
                <span asp-validation-for="MusicNote.InstrumentId"></span>
            </div>
            <div class="form-group">
                <label>عنوان نت</label>
                <input type="text" asp-for="MusicNote.Title" class="form-control">
            </div>
            <div class="form-group">
                <label>انتخاب فایل نت</label>
                <input type="file" name="imgLogo" id="imgLogo">
            </div>
            <div class="form-group">
                <img id="imgInstrumentLogo" class="thumbnail" src="/UserAvatar/Defult.jpg" alt="default" />
                <div class="form-group">
                    <label>عکس </label>
                    <input type="file" name="imgInstrumentLogoUp" id="imgInstrumentLogoUp">
                </div>

            </div>
            <input type="submit" value="ذخیره اطلاعات" class="btn btn-success" />

        </div>
    </form>
</div>

@section Scripts
{
    <script>
        function readURL(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#imgLogo').attr('src', e.target.result);
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        $("#imgLogo").change(function () {
            readURL(this);
        });

        function readURLImage(input) {

            if (input.files && input.files[0]) {
                var reader = new FileReader();

                reader.onload = function (e) {
                    $('#imgInstrument').attr('src', e.target.result);
                }

                reader.readAsDataURL(input.files[0]);
            }
        }

        function readURLLogo(input) {

            if (input.files && input.files[0]) {
                var reader = new FileReader();

                reader.onload = function (e) {
                    $('#imgInstrumentLogo').attr('src', e.target.result);
                }

                reader.readAsDataURL(input.files[0]);
            }
        }

        $("#imgInstrumentUp").change(function () {
            readURLImage(this);
        });
        $("#imgInstrumentLogoUp").change(function () {
            readURLLogo(this);
        });
    </script>

}




