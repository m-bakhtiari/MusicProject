@page "{id?}"
@model TopLearn.Web.Pages.Admin.CourseGroups.CreateGroupModel
@{
    ViewData["Title"] = "CreateGroup";
}


<div class="row">
    <div class="col-lg-12">
        <h1 class="page-header">افزودن گروه جدید</h1>
    </div>
    <!-- /.col-lg-12 -->
</div>

<div class="row">
    <form method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="CourseGroups.ParentId"/>
        <div class="col-md-12">
            <div class="panel panel-primary">
                <div class="panel-heading">
                   گروه جدید
                </div>
                <!-- /.panel-heading -->
                <div class="panel-body">
                    <div class="form-group">
                        <label>عنوان گروه</label>
                        <input type="text" asp-for="CourseGroups.GroupTitle" class="form-control">
                    </div>
                    <div class="form-group">
                        <img id="imgCourse" class="thumbnail" src="/UserAvatar/Defult.jpg" alt="logo" />
                        <div class="form-group">

                            <label>انتخاب تصویر</label>
                            <input type="file" name="imgLogo" id="imgLogo">
                        </div>

                    </div>
                    <input type="submit" value="ذخیره اطلاعات" class="btn btn-success" />
                </div>
                <!-- /.panel-body -->
            </div>
        </div>
  
    </form>
</div>


@section Scripts
{
    <script>
        function readURL(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#imgCourse').attr('src', e.target.result);
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        $("#imgLogo").change(function () {
            readURL(this);
        });
    </script>
}


