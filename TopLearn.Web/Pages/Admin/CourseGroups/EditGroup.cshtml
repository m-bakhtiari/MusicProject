@page "{id}"
@model TopLearn.Web.Pages.Admin.CourseGroups.EditGroupModel
@{
    ViewData["Title"] = "EditGroup";
}

<div class="row">
    <div class="col-lg-12">
        <h1 class="page-header">ویرایش گروه </h1>
    </div>
    <!-- /.col-lg-12 -->
</div>

<div class="row">
    <form method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="CourseGroups.ParentId" />
        <input type="hidden" asp-for="CourseGroups.GroupId" />
        <input type="hidden" asp-for="CourseGroups.ImageName" />
        <div class="col-md-12">
            <div class="panel panel-primary">
                <div class="panel-heading">
                    ویرایش گروه
                </div>
                <!-- /.panel-heading -->
                <div class="panel-body">
                    <div class="form-group">
                        <label>عنوان گروه</label>
                        <input type="text" asp-for="CourseGroups.GroupTitle" class="form-control">
                    </div>
                    <div class="form-group">
                        @if (Model.CourseGroups.ImageName == "no-photo.jpg")
                        {
                            <img id="imgCourse" class="thumbnail" src="/UserAvatar/Defult.jpg" alt="logo" />
                        }
                        else
                        {
                            <img id="imgCourse" src="/group/@Model.CourseGroups.ImageName" alt="logo" class="thumbnail" />
                        }
                        <div class="form-group">
                            <label>انتخاب تصویر</label>
                            <input type="file" name="imgLogo" id="imgLogo">
                        </div>
                    </div>
                    <input type="submit" value="ذخیره اطلاعات" class="btn btn-success" />
                </div>
                <!-- /.panel-body -->
            </div>
        </div>

    </form>
</div>

@section Scripts
{
    <script>
        function readURL(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#imgCourse').attr('src', e.target.result);
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        $("#imgLogo").change(function () {
            readURL(this);
        });
    </script>
}


