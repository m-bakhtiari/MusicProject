@page
@model TopLearn.Web.Pages.Admin.Courses.CreateCourseModel
@{
    ViewData["Title"] = "افزودن محصول جدید";
}

<div class="row">
    <form method="post" enctype="multipart/form-data">
        <div class="col-md-12">
            <h2>اطلاعات محصول</h2>
            <hr />
            <div class="form-group">
                <label>عنوان محصول</label>
                <input type="text" asp-for="Product.CourseTitle" class="form-control">
                <span asp-validation-for="Product.CourseTitle"></span>
            </div>
            <div class="form-group">
                <label>گروه اصلی</label>
                <select class="form-control" asp-for="Product.GroupId" asp-items="@(ViewData["Groups"] as SelectList)"></select>
                <span asp-validation-for="Product.GroupId"></span>
            </div>
            <div class="form-group">
                <label>گروه فرعی</label>
                <select class="form-control" asp-for="Product.SubGroup" asp-items="@(ViewData["SubGroups"] as SelectList)"></select>
                <span asp-validation-for="Product.SubGroup"></span>
            </div>
            <div class="form-group">
                <label>موجود برای خرید</label>
                <select class="form-control" asp-for="Product.IsAvailable">
                    <option value="false">اتمام موجودی</option>
                    <option value="true"> موجود</option>
                </select>
                <span asp-validation-for="Product.IsAvailable"></span>
            </div>
            <div class="form-group">
                <label>توضیح مخنصر</label>
                <input type="text" class="form-control" asp-for="Product.ShortDescription" />
                <span asp-validation-for="Product.ShortDescription"></span>
            </div>
            <div class="form-group">
                <label>شرح محصول</label>
                <textarea id="description" class="form-control" asp-for="Product.CourseDescription" rows="10"></textarea>
                <span asp-validation-for="Product.CourseDescription"></span>
            </div>
            <div class="form-group">
                <label>تعداد محصول</label>
                <input type="number" asp-for="Product.Quantity" class="form-control" />
                <span asp-validation-for="Product.Quantity"></span>
            </div>
            <div class="form-group">
                <label>قیمت محصول</label>
                <input type="number" asp-for="Product.CoursePrice" value="0" class="form-control" />
                <span asp-validation-for="Product.CourseDescription"></span>
            </div>
            <div class="form-group">
                <label>قیمت با تخفیف</label>
                <input type="number" asp-for="Product.SalePrice" class="form-control" />
                <span asp-validation-for="Product.SalePrice"></span>
            </div>
            <div class="form-group">
                <label>کلمات کلیدی محصول</label>
                <input type="text" asp-for="Product.Tags" class="form-control">
                <p class="help-block">کلمات را با - جدا کنید</p>
                <span asp-validation-for="Product.CourseTitle"></span>
            </div>
            <div class="form-group">
                <img id="imgCourse" class="thumbnail" src="/UserAvatar/Defult.jpg" />
                <div class="form-group">
                    <label>انتخاب تصویر</label>
                    <input type="file" name="imgCourseUp" id="imgCourseUp">
                </div>
            </div>

            <div class="form-group">
                <label>گالری تصاویر </label>
                <!-- اضافه کردن یک کلاس برای دسترسی راحت‌تر -->
                <input type="file" id="imageList" name="imageList" multiple class="file-input">
            </div>

            <div class="form-group">
                <div id="imagePreview"></div>
            </div>
            <input type="submit" value="ذخیره اطلاعات" class="btn btn-success" />
        </div>

    </form>
</div>

@section Scripts
{
   

    <script>
        $("#Course_GroupId").change(function () {
            $("#Course_SubGroup").empty();
            $.getJSON("/home/GetSubGroups/" + $("#Course_GroupId :selected").val(),
                function (data) {

                    $.each(data,
                        function () {
                            $("#Course_SubGroup").append('<option value=' + this.value + '>' + this.text + '</option>');

                        });

                });


        });

        function readURL(input) {

            if (input.files && input.files[0]) {
                var reader = new FileReader();

                reader.onload = function (e) {
                    $('#imgCourse').attr('src', e.target.result);
                }

                reader.readAsDataURL(input.files[0]);
            }
        }

        $("#imgCourseUp").change(function () {
            readURL(this);
        });
    </script>

    <script>
        // یک DataTransfer برای مدیریت فایل‌های انتخاب شده ایجاد می‌کنیم.
        var dt = new DataTransfer();

        function updatePreview() {
            $("#imagePreview").html("");
            // بررسی فایل‌هایی که در DataTransfer هستند
            for (let i = 0; i < dt.files.length; i++) {
                var file = dt.files[i];
                var reader = new FileReader();

                reader.onload = function (e) {
                    // ایجاد container برای هر عکس
                    var imgContainer = $("<div>").css({
                        "display": "inline-block",
                        "position": "relative",
                        "margin": "5px"
                    });

                    var img = $("<img>").attr("src", e.target.result).css({
                        "width": "250px",
                        "height": "250px",
                        "display": "block"
                    }).addClass("img-thumbnail");

                    // دکمه حذف برای هر عکس
                    var deleteButton = $("<button>").text("X").css({
                        "position": "absolute",
                        "top": "20px",
                        "right": "20px",
                        "background": "red",
                        "color": "white",
                        "border": "none",
                        "cursor": "pointer",
                        "padding": "2px 5px"
                    }).click(function () {
                        // حذف فایل از DataTransfer
                        dt.items.remove(i);
                        // به‌روزرسانی لیست فایل‌های موجود در فایل اینپوت.
                        $("#imageList").prop("files", dt.files);
                        // به‌روزرسانی نمایش تصاویر
                        updatePreview();
                    });

                    imgContainer.append(img).append(deleteButton);
                    $("#imagePreview").append(imgContainer);
                };

                reader.readAsDataURL(file);
            }
        }

        // هنگامی که کاربر فایل انتخاب می‌کند
        $("#imageList").on("change", function (e) {
            var files = e.target.files;
            // فایل‌های جدید به DataTransfer اضافه شوند
            for (let i = 0; i < files.length; i++) {
                dt.items.add(files[i]);
            }
            // ویژگی files اینپوت را به‌روز‌رسانی می‌کنیم
            $("#imageList").prop("files", dt.files);
            updatePreview();
        });
    </script>
}
