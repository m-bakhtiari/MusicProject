@page "{id}"
@model TopLearn.Web.Pages.Admin.Courses.EditCourseModel
@{
    ViewData["Title"] = "ویرایش محصول";
}

<div class="row">
    <form method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Product.CreateDate" />
        <input type="hidden" asp-for="Product.ProductId" />
        <input type="hidden" asp-for="Product.CourseImageName" />
        <div class="col-md-12">
            <h2>اطلاعات محصول</h2>
            <hr />
            <div class="form-group">
                <label>عنوان محصول</label>
                <input type="text" asp-for="Product.CourseTitle" class="form-control">
                <span asp-validation-for="Product.CourseTitle"></span>
            </div>
            <div class="form-group">
                <label>گروه اصلی</label>
                <select class="form-control" asp-for="Product.GroupId" asp-items="@(ViewData["Groups"] as SelectList)"></select>
                <span asp-validation-for="Product.GroupId"></span>
            </div>
            <div class="form-group">
                <label>گروه فرعی</label>
                <select class="form-control" asp-for="Product.SubGroup" asp-items="@(ViewData["SubGroups"] as SelectList)"></select>
                <span asp-validation-for="Product.SubGroup"></span>
            </div>

            <div class="form-group">
                <label>شرح محصول</label>
                <textarea id="description" class="form-control" asp-for="Product.CourseDescription" rows="10"></textarea>
                <span asp-validation-for="Product.CourseDescription"></span>
            </div>
            <div class="form-group">
                <label>قیمت محصول</label>
                <input type="number" asp-for="Product.CoursePrice" class="form-control" />
                <span asp-validation-for="Product.CoursePrice"></span>
            </div>
            <div class="form-group">
                <label>کلمات کلیدی محصول</label>
                <input type="text" asp-for="Product.Tags" class="form-control">
                <p class="help-block">کلمات را با - جدا کنید</p>
                <span asp-validation-for="Product.Tags"></span>
            </div>
            <div class="form-group">
                <p>تصویر فعلی</p>
                @if (Model.Product.CourseImageName == "no-photo.jpg")
                {
                    <img id="imgCourse" class="thumbnail" src="/UserAvatar/Defult.jpg" alt="image" />
                }
                else
                {
                    <img id="imgCourse" class="thumbnail" src="/course/@Model.Product.CourseImageName" alt="image" />
                }
                <div class="form-group">
                    <label>انتخاب تصویر</label>
                    <input type="file" name="imgCourseUp" id="imgCourseUp">
                </div>

            </div>
            @foreach (var item in Model.Product.ProductImages)
            {
                <div style="display: inline-block; position: relative; margin: 5px;" id="image-@item.ProductImageId">
                    <img src="/course/@item.ProductImageName" class="img-thumbnail" style="width: 250px; height: 250px;
                                                                                                display: block;" alt="تصویر کنسرت">
                    <button style="position: absolute; top: 20px; right: 20px; background: red; color: white; border: none;
                                       cursor: pointer; padding: 2px 5px;"
                            asp-page-handler="DeleteProductImage" asp-route-id="@item.ProductImageId">
                        X
                    </button>
                </div>
            }
            <div class="form-group">
                <label>گالری تصاویر</label>
                <!-- به این شیوه name به فایل ها اختصاص می‌یابد و در ارسال فرم دریافت می‌شود -->
                <input type="file" id="imageList" name="imageList" multiple>
            </div>
            <div class="form-group">
                <div id="imagePreview"></div>
            </div>
            <input type="submit" value="ذخیره اطلاعات" class="btn btn-success" />
        </div>
      
    </form>
</div>

@section Scripts
{

    <script>
        CKEDITOR.config.versionCheck = false;
        CKEDITOR.replace('description', {
            language: 'fa',
            contentsLangDirection: 'rtl', // جهت پیش‌فرض راست‌به‌چپ
            extraPlugins: 'bidi,justify', // فعال‌سازی پلاگین‌های جهت‌دهی و چینش
            toolbar: [
                { name: 'paragraph', items: ['BidiRtl', 'BidiLtr', '-', 'JustifyRight', 'JustifyCenter', 'JustifyLeft'] },
                { name: 'basicstyles', items: ['Bold', 'Italic', 'Underline','NumberedList', 'BulletedList'] },
                { name: 'clipboard', items: ['Undo', 'Redo'] },
                { name: 'editing', items: ['Scayt'] },
                { name: 'links', items: ['Link', 'Unlink'] },
                { name: 'insert', items: ['Image', 'Table'] },
                { name: 'styles', items: ['Format'] },
                { name: 'tools', items: ['Maximize'] }
            ]
        });


    </script>


    <script>
        $("#Course_GroupId").change(function () {
            $("#Course_SubGroup").empty();
            $.getJSON("/home/GetSubGroups/" + $("#Course_GroupId :selected").val(),
                function (data) {

                    $.each(data,
                        function () {
                            $("#Course_SubGroup").append('<option value=' + this.value + '>' + this.text + '</option>');

                        });

                });


        });

        function readURL(input) {

            if (input.files && input.files[0]) {
                var reader = new FileReader();

                reader.onload = function (e) {
                    $('#imgCourse').attr('src', e.target.result);
                }

                reader.readAsDataURL(input.files[0]);
            }
        }

        $("#imgCourseUp").change(function () {
            readURL(this);
        });
    </script>

    <script>
        // یک DataTransfer برای مدیریت فایل‌های انتخاب شده ایجاد می‌کنیم.
        var dt = new DataTransfer();

        function updatePreview() {
            $("#imagePreview").html("");
            // بررسی فایل‌هایی که در DataTransfer هستند
            for (var i = 0; i < dt.files.length; i++) {
                var file = dt.files[i];
                var reader = new FileReader();

                reader.onload = function (e) {
                    // ایجاد container برای هر عکس
                    var imgContainer = $("<div>").css({
                        "display": "inline-block",
                        "position": "relative",
                        "margin": "5px"
                    });

                    var img = $("<img>").attr("src", e.target.result).css({
                        "width": "250px",
                        "height": "250px",
                        "display": "block"
                    }).addClass("img-thumbnail");

                    // دکمه حذف برای هر عکس
                    var deleteButton = $("<button>").text("X").css({
                        "position": "absolute",
                        "top": "20px",
                        "right": "20px",
                        "background": "red",
                        "color": "white",
                        "border": "none",
                        "cursor": "pointer",
                        "padding": "2px 5px"
                    }).click(function () {
                        // حذف فایل از DataTransfer
                        dt.items.remove(i);
                        // به‌روزرسانی لیست فایل‌های موجود در فایل اینپوت.
                        $("#imageList").prop("files", dt.files);
                        // به‌روزرسانی نمایش تصاویر
                        updatePreview();
                    });

                    imgContainer.append(img).append(deleteButton);
                    $("#imagePreview").append(imgContainer);
                };

                reader.readAsDataURL(file);
            }
        }

        // هنگامی که کاربر فایل انتخاب می‌کند
        $("#imageList").on("change", function (e) {
            var files = e.target.files;
            // فایل‌های جدید به DataTransfer اضافه شوند
            for (let i = 0; i < files.length; i++) {
                dt.items.add(files[i]);
            }
            // ویژگی files اینپوت را به‌روز‌رسانی می‌کنیم
            $("#imageList").prop("files", dt.files);
            updatePreview();
        });

        // function deleteImage(id) {
        //     $.post("/Admin/Student/EditStudent?handler=DeleteStudentImage", { id: id })
        //         .done(function () {
        //             $("#image-" + id).remove(); // حذف تصویر از صفحه
        //         });

        // }


    </script>
}


