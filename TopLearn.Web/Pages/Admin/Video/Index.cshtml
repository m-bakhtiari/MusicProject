@page
@using TopLearn.Core.DTOs
@model TopLearn.Web.Pages.Admin.Video.IndexModel
@{
    ViewData["Title"] = "لیست ویدیو ها";
}

<div class="row">
    <div class="col-lg-12">
        <h1 class="page-header">لیست ویدیو ها</h1>
    </div>
    <!-- /.col-lg-12 -->
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="panel panel-default">
            <div class="panel-heading">
                لیست ویدیو ها
            </div>
            <!-- /.panel-heading -->
            <div class="panel-body">
                <div class="table-responsive">
                    <div id="dataTables-example_wrapper" class="dataTables_wrapper form-inline" role="grid">
                        <div class="col-md-12" style="margin: 10px 0;">
                            <a asp-page="CreateVideo" class="btn btn-outline btn-success">افزودن ویدیو جدید</a>
                        </div>
                        <table class="table table-striped table-bordered table-hover dataTable no-footer" id="dataTables-example" aria-describedby="dataTables-example_info">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>نوع ویدیو</th>
                                    <th>آدرس ویدیو</th>
                                    <th>عکس</th>
                                   
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Videos)
                                {
                                    <tr>
                                        <td>
                                            <a href="/Admin/Video/DeleteVideo/@item.VideoId" class="btn btn-info btn-sm mt-2">
                                                حذف
                                            </a>
                                            <a href="/Admin/Video/EditVideo/@item.VideoId" class="btn btn-warning btn-sm mt-2">
                                                ویرایش
                                            </a>
                                        </td>
                                        <td>
                                            @switch (item.VideoType)
                                            {                                           
                                                case (int)ConstantValue.VideoType.Learning:
                                                    @("آموزش")
                                                    break;
                                                case (int)ConstantValue.VideoType.Student:
                                                    @("هنرجویی")
                                                    break;
                                                case (int)ConstantValue.VideoType.Concert:
                                                    @("کنسرت ها")
                                                    break;
                                                default:
                                                    @("")
                                                    break;
                                            }
                                        </td>
                                        <td><a class="btn btn-primary" target="_blank" href="@item.VideoUrl">مشاهده ویدیو</a></td>
                                        <td>
                                            @if (string.IsNullOrWhiteSpace(item.ThumbnailImageUrl) == false)
                                            {
                                                <img src="@item.ThumbnailImageUrl" class="thumb thumbnail img-thumbnail" alt="image"/>
                                            }
                                            else if (string.IsNullOrWhiteSpace(item.ThumbnailImage) == false)
                                            {
                                                <img src="../video/@item.ThumbnailImage" class="thumb thumbnail img-thumbnail" alt="image" />
                                            }
                                        </td>
                                       
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
            <!-- /.panel-body -->
        </div>
        <!-- /.panel -->
    </div>
    <!-- /.col-lg-12 -->
</div>
