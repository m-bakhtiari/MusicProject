@page "{id}"
@using TopLearn.Core.DTOs
@model TopLearn.Web.Pages.Admin.Video.EditVideoModel
@{
    ViewData["Title"] = "ویرایش ویدیو";
}


<div class="row">
    <div class="col-lg-12">
        <h1 class="page-header">ویرایش ویدیو </h1>
    </div>
    <!-- /.col-lg-12 -->
</div>

<div class="row">
    <form method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Video.VideoId" />
        <input type="hidden" asp-for="Video.ThumbnailImage" />

        <!-- /.panel-heading -->
        <div class="col-md-12">
            <div class="form-group">
                <label>نوع ویدیو</label>
                <select class="form-control" asp-for="Video.VideoType">
                    <option value="1">آموزش</option>
                    <option value="2">هنرجویی</option>
                    <option value="3">کنسرت</option>
                </select>
            </div>
           
            <div class="form-group">
                <label>عنوان ویدیو</label>
                <input type="text" asp-for="Video.Title" class="form-control">
            </div>
            <div class="form-group">
                <a class="btn btn-primary" target="_blank" href="@Model.Video.VideoUrl">مشاهده ویدیو قبلی</a>
            </div>
            <div class="form-group">
                <label>لینک ویدیو</label>
                <input type="text" asp-for="Video.VideoUrl" class="form-control">
            </div>
            <div class="form-group">
                <label>آدرس تصویر</label>
                <input type="text" asp-for="Video.ThumbnailImageUrl" class="form-control">
            </div>
            <div class="form-group">
                @if (string.IsNullOrWhiteSpace(Model.Video.ThumbnailImage))
                {
                    <img id="imgCourse" class="thumbnail" src="/UserAvatar/Defult.jpg" alt="logo" />
                }
                else
                {
                    <img id="imgCourse" src="/Video/@Model.Video.ThumbnailImage" alt="logo" class="thumbnail" />
                }
                <div class="form-group">
                    <label>انتخاب تصویر</label>
                    <input type="file" name="imgLogo" id="imgLogo">
                </div>
            </div>
            <input type="submit" value="ذخیره اطلاعات" class="btn btn-success" />
        </div>

    </form>
</div>

@section Scripts
{
    <script>
        function readURL(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#imgCourse').attr('src', e.target.result);
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        $("#imgLogo").change(function () {
            readURL(this);
        });
    </script>
}



