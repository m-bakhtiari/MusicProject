@page
@using TopLearn.Core.DTOs

@model TopLearn.Web.Pages.Admin.Video.CreateVideoModel
@{
    ViewData["Title"] = "افزودن ویدیو جدید";
}


<div class="row">
    <div class="col-lg-12">
        <h1 class="page-header">افزودن ویدیو جدید</h1>
    </div>
    <!-- /.col-lg-12 -->
</div>

<div class="row">
    <form method="post" enctype="multipart/form-data">
        <div class="col-md-12">
            <div class="form-group">
                <label>نوع ویدیو</label>
                <select class="form-control" asp-for="Video.VideoType">
                    <option value="1">آموزش</option>
                    <option value="2">هنرجویی</option>
                    <option value="3">کنسرت</option>
                </select>
            </div>
            <div class="form-group">
                <label>عنوان ویدیو</label>
                <input type="text" asp-for="Video.Title" class="form-control">
            </div>
            <div class="form-group">
                <label>لینک ویدیو</label>
                <input type="text" asp-for="Video.VideoUrl" class="form-control">
            </div>
            <div class="form-group">
                <label>آدرس تصویر</label>
                <input type="text" asp-for="Video.ThumbnailImageUrl" class="form-control">
            </div>
            <div class="form-group">
                <img id="preview" class="thumbnail" src="/UserAvatar/Defult.jpg" alt="logo" />
                <div class="form-group">
                    <label>انتخاب تصویر</label>
                    <input type="file" name="imgLogo" id="imgLogo">
                </div>

            </div>
            <input type="submit" value="ذخیره اطلاعات" class="btn btn-success" />

        </div>

    </form>
</div>

@section Scripts
{
    <script>
        function readURL(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#preview').attr('src', e.target.result);
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        $("#imgLogo").change(function () {
            readURL(this);
        });
    </script>
}




